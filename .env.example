# ── Genesis environment template ──────────────────────────────────────
# Copy this file to `.env.local` and fill in the values.

# Frontend mock mode (default ON) — the site runs fully standalone.
NEXT_PUBLIC_USE_MOCKS=true

# Unsplash Access Key (Client-ID). Build-time only — used by the
# `npm run fetch:images` script to pull cinematic imagery into /public.
# Never exposed to the browser. Get a key at:
# https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
